# ==============================================================================
# AltRix School ERP — FastAPI Backend Environment Variables
# Copy this file to .env and configure the values for your environment (local/production).
# ==============================================================================

# ─── Application Settings ──────────────────────────────────────────────────────
APP_ENV=production
APP_NAME="AltRix School ERP API"
APP_VERSION=1.0.0
# The port the FastAPI server will listen on. Railway automatically provides this.
PORT=8000
DEBUG=False
# Generate a secure 64-character string using: openssl rand -hex 32
SECRET_KEY=change-this-to-a-secure-random-64-character-string-in-production

# ─── Database Configuration (Supabase PostgreSQL) ──────────────────────────────
# URL of your primary PostgreSQL database.
# Note: For async SQLAlchemy, a postgresql+asyncpg:// connection string is required.
# The code will auto-convert postgres:// and postgresql:// to postgresql+asyncpg:// on startup.
DATABASE_URL=postgresql://postgres.yourproject:yourpassword@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Database Connection Pooling Config (High Load Optimizations)
# Use "queue" for persistent servers (Railway, VPS, EC2) or "null" for serverless (Vercel)
DB_POOL_TYPE=queue
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20

# ─── Supabase Configuration ──────────────────────────────────────────────────
# Found in Supabase Dashboard → Settings → API
SUPABASE_URL=https://yourprojectid.supabase.co
# Used to verify authorization tokens (JWTs) from the frontend
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-key-must-be-exact
# anon key for public operations
SUPABASE_ANON_KEY=your-supabase-anon-key
# service role key for admin/bypass-RLS operations (keep extremely secure)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Redis Caching and Celery Task Queue ──────────────────────────────────────
# Redis URL used for WebSocket pub/sub, caching, and Celery task broker/backend
# Locally: redis://localhost:6379/0
# Railway/VPS: redis://:password@host:port/0 or rediss://... for SSL Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
CACHE_TTL_SECONDS=300
CACHE_ENABLED=True

# ─── CORS Origins ─────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to access this API.
# Do NOT include trailing slashes. Include your production Vercel frontend and localhost.
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:8080,http://localhost:5173

# ─── JazzCash Payment Gateway ─────────────────────────────────────────────────
# Integration credentials for JazzCash. Leave empty if payments are not used yet.
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=http://localhost:8000/api/payments/jazzcash/callback
JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Required for AI modules (e.g. AI Timetable Generator)
GEMINI_API_KEY=

# ─── Sentry Error Monitoring ──────────────────────────────────────────────────
# Optional: DSN for Sentry error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── JWT Authentication Settings ──────────────────────────────────────────────
# Optional: Override default JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Rate Limiting Settings ───────────────────────────────────────────────────
# Optional: Override default rate limits
RATE_LIMIT_LOGIN="5/minute"
RATE_LIMIT_PASSWORD_RESET="3/5minutes"
RATE_LIMIT_API="100/minute"

