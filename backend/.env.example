# Supabase JWT secret (found in Supabase Dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase service role key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase URL
SUPABASE_URL=https://nlbsuxxogzbyegtknpxg.supabase.co

# CORS origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# App settings
APP_ENV=development
SECRET_KEY=change-this-in-production-use-random-64-chars

# JazzCash credentials
